{
  "name": "A_FETCH_NEWSLETTER",
  "version": "1.0.0",
  "description": "Fetch the latest newsletter email body via the email CLI — configurable search query and sender filter",
  "input": {
    "account": { "type": "string" },
    "searchQuery": { "type": "string", "required": true },
    "fromAddress": { "type": "string" }
  },
  "output": {
    "emailBody": { "type": "string" },
    "emailSubject": { "type": "string" },
    "emailUid": { "type": "number" }
  },
  "requires": ["shell"],
  "tags": ["email", "newsletter", "harvest"]
}
